# Supabase
# Public (browser) - do NOT commit real keys here; set values in apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (don’t expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (server-only)
OPENAI_API_KEY=

# Stripe (server-only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (server-only)
RESEND_API_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=